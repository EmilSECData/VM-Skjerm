<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VM 2026 – Kommende kamper</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --pitch-night:#0c2419;
    --pitch-mid:#143625;
    --pitch-card:#193f2a;
    --hair:rgba(244,242,236,0.10);
    --gold:#e7b84a;
    --gold-dim:#bd9743;
    --chalk:#f4f2ec;
    --sage:#86a596;
    --norway:#c5132f;
    --live:#e0432f;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{
    width:100%; height:100%;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(231,184,74,0.10), transparent 60%),
      radial-gradient(ellipse 60% 50% at 100% 100%, rgba(255,255,255,0.04), transparent 60%),
      var(--pitch-night);
    color:var(--chalk);
    font-family:'Inter',sans-serif;
    overflow:auto; /* trygt fallback: scroller heller enn å klippe innhold hvis en iframe er lavere enn forventet */
  }
  .app{
    display:flex; flex-direction:column;
    width:100%; height:100vh; /* fyller hele iframens/vinduets høyde, både frittstående og embedded */
    min-height:560px;
  }
  @supports (height: 100dvh){
    .app{ height:100dvh; }
  }

  /* ---------- TOPBAR ---------- */
  .topbar{
    display:flex; align-items:center; justify-content:space-between;
    padding: clamp(10px,1.5vh,18px) clamp(20px,2.2vw,40px);
    border-bottom:1px solid var(--hair);
    flex-shrink:0;
  }
  .brand{display:flex; align-items:center; gap:12px;}
  .brand-mark{
    width:clamp(22px,1.9vw,30px); height:clamp(22px,1.9vw,30px);
    border-radius:50%; border:2.5px solid var(--gold);
    position:relative; flex-shrink:0;
  }
  .brand-mark::after{
    content:""; position:absolute; inset:30%;
    border-radius:50%; background:var(--gold);
  }
  .brand-title{
    font-family:'Oswald',sans-serif; font-weight:700;
    letter-spacing:0.04em; text-transform:uppercase;
    font-size:clamp(15px,1.7vw,23px);
    color:var(--chalk);
  }
  .brand-title span{color:var(--gold);}
  .clock{text-align:right;}
  .clock-time{
    font-family:'Space Mono',monospace; font-weight:700;
    font-size:clamp(16px,1.8vw,24px);
    letter-spacing:0.02em; color:var(--gold);
    line-height:1;
  }
  .clock-date{
    font-size:clamp(9.5px,0.85vw,12px);
    color:var(--sage); text-transform:capitalize;
    margin-top:3px;
  }

  /* ---------- FLAGS ---------- */
  .flagwrap{
    display:inline-flex; vertical-align:middle; border-radius:2px;
    overflow:hidden; box-shadow:0 0 0 1px rgba(255,255,255,0.18);
    flex-shrink:0;
  }
  .flagwrap svg{display:block;}

  /* ---------- NORWAY SECTION ---------- */
  .norway-section{
    flex-shrink:0;
    padding: clamp(8px,1.3vh,14px) clamp(20px,2.2vw,40px);
    border-bottom:1px solid var(--hair);
    background:linear-gradient(180deg, rgba(197,19,47,0.10), transparent);
  }
  .norway-title{
    display:flex; align-items:center; gap:8px;
    font-family:'Oswald',sans-serif; font-weight:700; text-transform:uppercase;
    letter-spacing:0.1em; font-size:clamp(11px,1.05vw,14px); color:var(--norway);
    margin-bottom:clamp(6px,0.9vh,10px);
  }
  .norway-grid{
    display:grid; grid-template-columns:repeat(3,1fr);
    gap:clamp(10px,1.3vw,18px);
  }
  .norway-card{
    background:var(--pitch-card); border:1px solid rgba(197,19,47,0.35);
    border-radius:10px; padding:clamp(7px,1vh,12px) clamp(10px,1.3vw,16px);
    display:flex; flex-direction:column; gap:4px;
  }
  .norway-card .matchup{
    display:flex; align-items:center; justify-content:center; gap:7px;
    font-family:'Oswald',sans-serif; font-weight:600; text-transform:uppercase;
    font-size:clamp(12px,1.15vw,15px); flex-wrap:wrap;
  }
  .norway-card .when{
    text-align:center; font-size:clamp(9px,0.8vw,11px); color:var(--sage);
  }
  .norway-card .status{
    text-align:center; font-family:'Space Mono',monospace; font-weight:700;
    font-size:clamp(11px,1.05vw,14px); color:var(--gold);
  }
  .norway-card .status.done{color:var(--sage); font-family:'Inter',sans-serif; font-weight:600;}
  .norway-card .status.live{color:var(--live); font-family:'Inter',sans-serif; font-weight:700;}
  .norway-card .status .unit{
    font-family:'Inter',sans-serif; font-weight:500; font-size:0.7em;
    color:var(--sage); margin:0 1px; text-transform:lowercase;
  }
  .pulse-dot{
    display:inline-block; width:7px; height:7px; border-radius:50%;
    background:var(--live); margin-right:6px; animation:pulse 1.4s infinite;
  }

  /* ---------- BOARD (3 kolonner – fyller bredden på liggende skjermer) ---------- */
  .board{
    flex:1; min-height:0;
    display:grid; grid-template-columns:repeat(3,1fr);
    gap:clamp(10px,1.3vw,20px);
    padding: clamp(10px,1.5vh,18px) clamp(20px,2.2vw,40px) clamp(8px,1.1vh,14px);
  }
  .board-col{
    min-height:0; display:flex; flex-direction:column;
    background:rgba(255,255,255,0.018);
    border:1px solid var(--hair); border-radius:14px;
    padding: clamp(10px,1.4vh,16px) clamp(10px,1.2vw,16px);
  }
  .colHeader{
    flex-shrink:0; display:flex; align-items:baseline; gap:9px; flex-wrap:wrap;
    margin-bottom:clamp(6px,1vh,12px);
    border-bottom:1px solid var(--hair); padding-bottom:clamp(6px,0.9vh,10px);
  }
  .colHeader .dname{
    font-family:'Oswald',sans-serif; font-weight:700; text-transform:uppercase;
    letter-spacing:0.02em; font-size:clamp(13px,1.25vw,17px); color:var(--chalk);
  }
  .colHeader .badge{
    font-size:clamp(8.5px,0.78vw,11px); font-weight:600; letter-spacing:0.08em;
    text-transform:uppercase; color:var(--pitch-night);
    background:var(--gold); padding:2px 9px; border-radius:10px;
  }
  .board-rows{
    flex:1; min-height:0; display:flex; flex-direction:column;
    justify-content:space-evenly; gap:clamp(5px,0.9vh,10px);
  }
  .board-row{
    flex:0 0 auto;
    display:grid; grid-template-columns:clamp(40px,3.6vw,54px) 1fr clamp(46px,4.6vw,64px);
    align-items:center; gap:clamp(6px,0.9vw,12px);
    background:var(--pitch-card);
    border:1px solid var(--hair); border-radius:10px;
    padding:clamp(6px,0.9vh,11px) clamp(8px,0.9vw,13px);
  }
  .board-row.norway{
    border-color:var(--norway);
    box-shadow: inset 3px 0 0 var(--norway);
    background:linear-gradient(90deg, rgba(197,19,47,0.14), var(--pitch-card) 35%);
  }
  .board-row .time{
    font-family:'Space Mono',monospace; font-weight:700;
    font-size:clamp(11.5px,1.1vw,15px); color:var(--gold);
    text-align:center;
  }
  .teams{
    display:flex; align-items:center; justify-content:center;
    gap:clamp(5px,0.6vw,9px); flex-wrap:wrap;
    font-family:'Oswald',sans-serif; font-weight:600; text-transform:uppercase;
    font-size:clamp(10px,0.92vw,13px); color:var(--chalk); line-height:1.15;
  }
  .team{display:flex; align-items:center; gap:5px;}
  .dot{width:0.55em; height:0.55em; border-radius:50%; flex-shrink:0;}
  .teams .vs{color:var(--sage); font-weight:400; font-size:0.8em;}
  .meta{display:flex; flex-direction:column; align-items:flex-end; gap:3px;}
  .group-tag{
    font-size:clamp(7.5px,0.7vw,9.5px); color:var(--sage); letter-spacing:0.06em;
    text-transform:uppercase;
  }
  .live-tag{
    font-size:clamp(7.5px,0.7vw,9.5px); font-weight:700; letter-spacing:0.08em;
    color:var(--live); display:flex; align-items:center; gap:4px;
  }
  .live-tag .pulse{
    width:6px; height:6px; border-radius:50%; background:var(--live);
    animation:pulse 1.4s infinite;
  }
  .norway-tag{
    font-size:clamp(7.5px,0.7vw,9.5px); font-weight:700; letter-spacing:0.06em;
    color:var(--norway); display:flex; align-items:center; gap:4px;
  }
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.25;}}

  .muted-msg{
    margin:auto; color:var(--sage); font-size:clamp(11px,1vw,14px); text-align:center;
  }

  .info-col .board-rows{justify-content:flex-start; gap:clamp(6px,1vh,11px);}
  .info-row{
    flex:0 0 auto;
    display:flex; align-items:center; justify-content:space-between;
    background:var(--pitch-card); border:1px solid var(--hair); border-radius:10px;
    padding:clamp(7px,1vh,12px) clamp(10px,1vw,14px);
    font-size:clamp(10.5px,0.95vw,13px);
  }
  .info-row span:first-child{font-family:'Oswald',sans-serif; font-weight:600; text-transform:uppercase; letter-spacing:0.03em;}
  .info-row span:last-child{font-family:'Space Mono',monospace; color:var(--gold); font-weight:700; font-size:0.95em;}
  .info-row.highlight{border-color:var(--gold-dim); background:linear-gradient(90deg, rgba(231,184,74,0.12), var(--pitch-card));}

  /* ---------- TICKER ---------- */
  .ticker{
    flex-shrink:0; border-top:1px solid var(--hair);
    background:var(--pitch-mid);
    overflow:hidden; white-space:nowrap;
    padding: clamp(6px,1vh,10px) 0;
  }
  .ticker-track{
    display:inline-block; padding-left:100%;
    animation:scroll 42s linear infinite;
    font-size:clamp(10.5px,1vw,13px); color:var(--sage);
    letter-spacing:0.02em;
  }
  .ticker-track b{color:var(--gold); font-weight:600;}
  .ticker-track .sep{color:var(--gold-dim); margin:0 18px;}
  .ticker-track .flagwrap{margin-right:6px;}
  @keyframes scroll{0%{transform:translateX(0);}100%{transform:translateX(-100%);}}

  .fallback{
    flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:10px; text-align:center; padding:0 20px;
  }
  .fallback h2{font-family:'Oswald',sans-serif; font-size:clamp(18px,2.4vw,26px); text-transform:uppercase;}
  .fallback p{color:var(--sage); font-size:clamp(12px,1.1vw,15px); max-width:600px;}

  /* ---------- PORTRETT-SKJERMER ---------- */
  /* Samme fil, men 3 smale kolonner side ved side blir uleselig på en stående skjerm,
     så her stables dag-panelene under hverandre i stedet, og bruker hele bredden hver. */
  @media (orientation: portrait){
    .board{
      grid-template-columns: 1fr;
      grid-template-rows: repeat(3, 1fr);
      gap: clamp(8px,1.2vh,14px);
    }
    .norway-grid{
      grid-template-columns: 1fr;
    }
    .board-row{
      grid-template-columns: clamp(50px,11vw,68px) 1fr clamp(56px,13vw,80px);
    }
  }
</style>
</head>
<body>
<div class="app">

  <header class="topbar">
    <div class="brand">
      <div class="brand-mark"></div>
      <div class="brand-title">FOTBALL-VM <span>2026</span></div>
    </div>
    <div class="clock">
      <div class="clock-time" id="clockTime">--:--:--</div>
      <div class="clock-date" id="clockDate">–</div>
    </div>
  </header>

  <section class="norway-section" id="norwaySection"></section>

  <main class="board" id="board"></main>

  <footer class="ticker">
    <div class="ticker-track" id="tickerTrack"></div>
  </footer>

</div>

<script>
/* ===================== FARGER & FLAGG ===================== */
const COLORS = {
  TSJ:"#D7141A", RSA:"#007A4D", SUI:"#FF0000", BIH:"#002395", CAN:"#FF0000", QAT:"#8A1538",
  MEX:"#006847", KOR:"#C60C30", USA:"#3C3B6E", AUS:"#00843D", SCO:"#0065BD", MAR:"#C1272D",
  BRA:"#FFDF00", HAI:"#00209F", NED:"#FF6600", SWE:"#FFCD00", GER:"#9a9a9a", CIV:"#FF8200",
  TUR:"#E30A17", PAR:"#0038A8", ECU:"#FFDD00", CUW:"#3a6bcf", TUN:"#E70013", JPN:"#BC002D",
  ESP:"#C60B1E", KSA:"#1f9d56", BEL:"#ED2939", IRN:"#239F40", URU:"#1B98E0", CPV:"#3a5fbf",
  NZL:"#cfcfcf", EGY:"#C8102E", ARG:"#74ACDF", AUT:"#ED2939", FRA:"#0055A4", IRQ:"#CE1126",
  NOR:"#c5132f", SEN:"#00853F", JOR:"#bfbfbf", ALG:"#006233", POR:"#FF0000", UZB:"#0099B5",
  ENG:"#C8102E", GHA:"#FCD116", PAN:"#005293", CRO:"#5b6fd1", COL:"#FCD116", COD:"#3a8bff"
};

// Forenklede, men proporsjonalt riktige flagg som SVG (robust på alle skjermer/nettlesere,
// i motsetning til emoji-flagg som ofte vises feil på digitale infoskjermer).
function flagSVG(code, w, h){
  w = w || 22; h = h || 16;
  const ns = 'xmlns="http://www.w3.org/2000/svg"';
  const flags = {
    NOR: `<svg viewBox="0 0 22 16" width="${w}" height="${h}" ${ns}>
            <rect width="22" height="16" fill="#BA0C2F"/>
            <rect x="6" width="4" height="16" fill="#fff"/>
            <rect y="6" width="22" height="4" fill="#fff"/>
            <rect x="7" width="2" height="16" fill="#00205B"/>
            <rect y="7" width="22" height="2" fill="#00205B"/>
          </svg>`,
    FRA: `<svg viewBox="0 0 3 2" width="${w}" height="${h}" ${ns}>
            <rect width="1" height="2" fill="#0055A4"/>
            <rect x="1" width="1" height="2" fill="#fff"/>
            <rect x="2" width="1" height="2" fill="#EF4135"/>
          </svg>`,
    SEN: `<svg viewBox="0 0 3 2" width="${w}" height="${h}" ${ns}>
            <rect width="1" height="2" fill="#00853F"/>
            <rect x="1" width="1" height="2" fill="#FDEF42"/>
            <rect x="2" width="1" height="2" fill="#E31B23"/>
            <polygon fill="#00853F" points="1.5,0.67 1.58,0.90 1.81,0.90 1.62,1.04 1.69,1.27 1.5,1.13 1.31,1.27 1.38,1.04 1.19,0.90 1.42,0.90"/>
          </svg>`,
    IRQ: `<svg viewBox="0 0 3 2" width="${w}" height="${h}" ${ns}>
            <rect width="3" height="0.667" fill="#CE1126"/>
            <rect y="0.667" width="3" height="0.667" fill="#fff"/>
            <rect y="1.333" width="3" height="0.667" fill="#1A1A1A"/>
          </svg>`
  };
  return flags[code] || '';
}
const HAS_FLAG = ['NOR','FRA','SEN','IRQ'];
function teamMark(code){
  if(HAS_FLAG.includes(code)) return `<span class="flagwrap">${flagSVG(code,20,14)}</span>`;
  return `<span class="dot" style="background:${COLORS[code]||'#888'}"></span>`;
}

/* ===================== KAMPDATA (gruppespill, 18.–28. juni) ===================== */
// Alle klokkeslett er norsk sommertid (CEST, UTC+2).
function M(d,t,g,h,hc,a,ac,no){ return {d,t,g,h,hc,a,ac,no:!!no}; }

const RAW = [
  M("2026-06-18","18:00","A","Tsjekkia","TSJ","Sør-Afrika","RSA"),
  M("2026-06-18","21:00","B","Sveits","SUI","Bosnia-Hercegovina","BIH"),

  M("2026-06-19","00:00","B","Canada","CAN","Qatar","QAT"),
  M("2026-06-19","03:00","A","Mexico","MEX","Sør-Korea","KOR"),
  M("2026-06-19","21:00","D","USA","USA","Australia","AUS"),

  M("2026-06-20","00:00","C","Skottland","SCO","Marokko","MAR"),
  M("2026-06-20","03:00","C","Brasil","BRA","Haiti","HAI"),
  M("2026-06-20","06:00","D","Tyrkia","TUR","Paraguay","PAR"),
  M("2026-06-20","19:00","F","Nederland","NED","Sverige","SWE"),
  M("2026-06-20","22:00","E","Tyskland","GER","Elfenbenskysten","CIV"),

  M("2026-06-21","02:00","E","Ecuador","ECU","Curaçao","CUW"),
  M("2026-06-21","06:00","F","Tunisia","TUN","Japan","JPN"),
  M("2026-06-21","18:00","H","Spania","ESP","Saudi-Arabia","KSA"),
  M("2026-06-21","21:00","G","Belgia","BEL","Iran","IRN"),

  M("2026-06-22","00:00","H","Uruguay","URU","Kapp Verde","CPV"),
  M("2026-06-22","03:00","G","New Zealand","NZL","Egypt","EGY"),
  M("2026-06-22","19:00","J","Argentina","ARG","Østerrike","AUT"),
  M("2026-06-22","23:00","I","Frankrike","FRA","Irak","IRQ"),

  M("2026-06-23","02:00","I","Norge","NOR","Senegal","SEN", true),
  M("2026-06-23","05:00","J","Jordan","JOR","Algerie","ALG"),
  M("2026-06-23","19:00","K","Portugal","POR","Uzbekistan","UZB"),
  M("2026-06-23","22:00","L","England","ENG","Ghana","GHA"),

  M("2026-06-24","01:00","L","Panama","PAN","Kroatia","CRO"),
  M("2026-06-24","04:00","K","Colombia","COL","DR Kongo","COD"),
  M("2026-06-24","21:00","B","Sveits","SUI","Canada","CAN"),
  M("2026-06-24","21:00","B","Bosnia-Hercegovina","BIH","Qatar","QAT"),

  M("2026-06-25","00:00","C","Skottland","SCO","Brasil","BRA"),
  M("2026-06-25","00:00","C","Marokko","MAR","Haiti","HAI"),
  M("2026-06-25","03:00","A","Tsjekkia","TSJ","Mexico","MEX"),
  M("2026-06-25","03:00","A","Sør-Afrika","RSA","Sør-Korea","KOR"),
  M("2026-06-25","22:00","E","Ecuador","ECU","Tyskland","GER"),
  M("2026-06-25","22:00","E","Curaçao","CUW","Elfenbenskysten","CIV"),

  M("2026-06-26","01:00","F","Japan","JPN","Sverige","SWE"),
  M("2026-06-26","01:00","F","Tunisia","TUN","Nederland","NED"),
  M("2026-06-26","04:00","D","Tyrkia","TUR","USA","USA"),
  M("2026-06-26","04:00","D","Paraguay","PAR","Australia","AUS"),
  M("2026-06-26","21:00","I","Norge","NOR","Frankrike","FRA", true),
  M("2026-06-26","21:00","I","Senegal","SEN","Irak","IRQ"),

  M("2026-06-27","02:00","H","Kapp Verde","CPV","Saudi-Arabia","KSA"),
  M("2026-06-27","02:00","H","Uruguay","URU","Spania","ESP"),
  M("2026-06-27","05:00","G","Egypt","EGY","Iran","IRN"),
  M("2026-06-27","05:00","G","New Zealand","NZL","Belgia","BEL"),
  M("2026-06-27","23:00","L","Panama","PAN","England","ENG"),
  M("2026-06-27","23:00","L","Kroatia","CRO","Ghana","GHA"),

  M("2026-06-28","01:30","K","Colombia","COL","Portugal","POR"),
  M("2026-06-28","01:30","K","DR Kongo","COD","Uzbekistan","UZB"),
  M("2026-06-28","04:00","J","Algerie","ALG","Østerrike","AUT"),
  M("2026-06-28","04:00","J","Jordan","JOR","Argentina","ARG"),
];

const MATCH_MIN = 130; // ca. lengde på en kamp inkl. pause, i minutter
const matches = RAW.map(m=>{
  const kickoff = new Date(`${m.d}T${m.t}:00+02:00`);
  const end = new Date(kickoff.getTime() + MATCH_MIN*60000);
  return {...m, kickoff, end};
}).sort((a,b)=>a.kickoff-b.kickoff);

/* ===================== NORGES KAMPER (egen del) ===================== */
const NORWAY_FIXTURES = [
  {opp:"Irak", code:"IRQ", date:"2026-06-17", time:"00:00", city:"Boston", played:true, scoreNor:4, scoreOpp:1},
  {opp:"Senegal", code:"SEN", date:"2026-06-23", time:"02:00", city:"New York/New Jersey", played:false},
  {opp:"Frankrike", code:"FRA", date:"2026-06-26", time:"21:00", city:"Boston", played:false},
].map(f=>{
  const kickoff = new Date(`${f.date}T${f.time}:00+02:00`);
  const end = new Date(kickoff.getTime() + MATCH_MIN*60000);
  return {...f, kickoff, end};
});

function renderNorway(){
  const now = new Date();
  const cards = NORWAY_FIXTURES.map(f=>{
    let statusHtml;
    if(now>=f.kickoff && now<f.end){
      statusHtml = `<div class="status live"><span class="pulse-dot"></span>PÅGÅR NÅ</div>`;
    } else if(f.played || now>=f.end){
      statusHtml = f.played
        ? `<div class="status done">Ferdig spilt · Norge ${f.scoreNor}–${f.scoreOpp}</div>`
        : `<div class="status done">Avsluttet</div>`;
    } else {
      statusHtml = `<div class="status" data-countdown="${f.kickoff.toISOString()}">beregner …</div>`;
    }
    return `
      <div class="norway-card">
        <div class="matchup">
          <span class="flagwrap">${flagSVG('NOR',20,14)}</span><span>Norge</span>
          <span style="color:var(--sage)">–</span>
          <span>${f.opp}</span><span class="flagwrap">${flagSVG(f.code,20,14)}</span>
        </div>
        <div class="when">${f.kickoff.toLocaleDateString('nb-NO',{timeZone:'Europe/Oslo',weekday:'short',day:'numeric',month:'short'})} · kl. ${f.time} norsk tid · ${f.city}</div>
        ${statusHtml}
      </div>`;
  }).join('');

  document.getElementById('norwaySection').innerHTML = `
    <div class="norway-title"><span class="flagwrap">${flagSVG('NOR',16,12)}</span> Norges kamper · Gruppe I</div>
    <div class="norway-grid">${cards}</div>
  `;
  updateNorwayCountdowns();
}

function updateNorwayCountdowns(){
  document.querySelectorAll('#norwaySection .status[data-countdown]').forEach(el=>{
    const target = new Date(el.dataset.countdown);
    const diff = target - new Date();
    if(diff<=0){ renderNorway(); return; }
    const dd = Math.floor(diff/86400000);
    const hh = Math.floor((diff%86400000)/3600000);
    const mm = Math.floor((diff%3600000)/60000);
    const ss = Math.floor((diff%60000)/1000);
    let str = '';
    if(dd>0) str += `${dd}<span class="unit">d</span> `;
    str += `${String(hh).padStart(2,'0')}<span class="unit">t</span> ${String(mm).padStart(2,'0')}<span class="unit">min</span> ${String(ss).padStart(2,'0')}<span class="unit">sek</span>`;
    el.innerHTML = str;
  });
}

/* ===================== KLOKKE ===================== */
function updateClock(){
  const now = new Date();
  document.getElementById('clockTime').textContent =
    now.toLocaleTimeString('nb-NO', {timeZone:'Europe/Oslo', hour:'2-digit', minute:'2-digit', second:'2-digit'});
  document.getElementById('clockDate').textContent =
    now.toLocaleDateString('nb-NO', {timeZone:'Europe/Oslo', weekday:'long', day:'numeric', month:'long'});
}

/* ===================== BOARD: 3 kolonner side ved side ===================== */
// Kolonne 1 = neste dag med kamper, kolonne 2 = dagen etter der,
// kolonne 3 = roterer gjennom resten av kampdagene (eller viser veikartet videre hvis ingen flere).
function getDayGroups(){
  const now = new Date();
  const upcoming = matches.filter(m=> m.end > now);
  const byDate = {};
  upcoming.forEach(m=>{
    if(!byDate[m.d]) byDate[m.d] = [];
    byDate[m.d].push(m);
  });
  return Object.keys(byDate).sort().map(d=>({date:d, list:byDate[d]}));
}

function dayBadge(dateStr, todayStr, tomorrowStr){
  if(dateStr===todayStr) return '<span class="badge">I dag</span>';
  if(dateStr===tomorrowStr) return '<span class="badge">I morgen</span>';
  return '';
}

function renderMatchRow(m, now){
  const isLive = now>=m.kickoff && now<m.end;
  return `<div class="board-row ${m.no?'norway':''}">
      <div class="time">${m.t}</div>
      <div class="teams">
        <span class="team">${teamMark(m.hc)}${m.h}</span>
        <span class="vs">–</span>
        <span class="team">${teamMark(m.ac)}${m.a}</span>
      </div>
      <div class="meta">
        ${isLive ? '<div class="live-tag"><span class="pulse"></span>LIVE</div>' : `<div class="group-tag">Gr. ${m.g}</div>`}
        ${m.no ? `<div class="norway-tag"><span class="flagwrap">${flagSVG('NOR',11,8)}</span>Norge</div>` : ''}
      </div>
    </div>`;
}

function renderColumn(group, now, todayStr, tomorrowStr){
  if(!group){
    return `<div class="board-col"><div class="colHeader"><span class="dname">–</span></div>
      <div class="board-rows" style="justify-content:center;"><p class="muted-msg">Ingen flere kamper i denne perioden</p></div></div>`;
  }
  const dateObj = new Date(group.date+'T12:00:00+02:00');
  const dname = dateObj.toLocaleDateString('nb-NO',{timeZone:'Europe/Oslo', weekday:'long', day:'numeric', month:'long'});
  const badge = dayBadge(group.date, todayStr, tomorrowStr);
  const rows = group.list.map(m=>renderMatchRow(m,now)).join('');
  return `<div class="board-col">
    <div class="colHeader"><span class="dname">${dname}</span>${badge}</div>
    <div class="board-rows">${rows}</div>
  </div>`;
}

function renderInfoColumn(){
  return `<div class="board-col info-col">
    <div class="colHeader"><span class="dname">Veien videre</span></div>
    <div class="board-rows">
      <div class="info-row"><span>32-delsfinaler</span><span>28. jun–3. jul</span></div>
      <div class="info-row"><span>Åttedelsfinaler</span><span>4.–7. jul</span></div>
      <div class="info-row"><span>Kvartfinaler</span><span>9.–12. jul</span></div>
      <div class="info-row"><span>Semifinaler</span><span>14.–15. jul</span></div>
      <div class="info-row"><span>Bronsefinale</span><span>18. jul</span></div>
      <div class="info-row highlight"><span>Finale</span><span>19. jul</span></div>
    </div>
  </div>`;
}

let laterIndex = 0;

function renderBoard(){
  const board = document.getElementById('board');
  const groups = getDayGroups();

  if(groups.length===0){
    board.innerHTML = `<div class="fallback" style="grid-column:1/-1;">
      <h2>Ingen flere gruppespillkamper</h2>
      <p>Gruppespillet er avsluttet. Sjekk fotball.no, NRK eller TV 2 for fullt oppsett i sluttspillet.</p>
    </div>`;
    return;
  }

  const now = new Date();
  const todayStr = now.toLocaleDateString('en-CA',{timeZone:'Europe/Oslo'});
  const tomorrowStr = new Date(Date.now()+86400000).toLocaleDateString('en-CA',{timeZone:'Europe/Oslo'});

  const col1 = groups[0];
  const col2 = groups[1];
  const laterGroups = groups.slice(2);

  let col3html;
  if(laterGroups.length===0){
    col3html = renderInfoColumn();
  } else {
    if(laterIndex>=laterGroups.length) laterIndex = 0;
    col3html = renderColumn(laterGroups[laterIndex], now, todayStr, tomorrowStr);
  }

  board.innerHTML =
    renderColumn(col1, now, todayStr, tomorrowStr) +
    renderColumn(col2, now, todayStr, tomorrowStr) +
    col3html;
}

function advanceLater(){
  const groups = getDayGroups();
  const laterGroups = groups.slice(2);
  if(laterGroups.length > 1){
    laterIndex = (laterIndex+1) % laterGroups.length;
  }
  renderBoard();
}

/* ===================== TICKER ===================== */
function renderTicker(){
  const norFlag = flagSVG('NOR',16,11);
  const text = `
    <span><b>Veien videre:</b> 32-delsfinaler 28. juni–3. juli <span class="sep">·</span> Åttedelsfinaler 4.–7. juli <span class="sep">·</span> Kvartfinaler 9.–12. juli <span class="sep">·</span> Semifinaler 14.–15. juli <span class="sep">·</span> Bronsefinale 18. juli <span class="sep">·</span> <b>Finale 19. juli</b>, MetLife Stadium</span>
    <span class="sep">&nbsp;&nbsp;&nbsp;&nbsp;</span>
    <span><span class="flagwrap">${norFlag}</span>Går Norge videre fra gruppespillet: som gruppevinner spilles 32-delsfinalen <b>30. juni kl. 23:00</b> · som nr. 2 i gruppen <b>30. juni kl. 19:00</b> norsk tid</span>
    <span class="sep">&nbsp;&nbsp;&nbsp;&nbsp;</span>
  `;
  document.getElementById('tickerTrack').innerHTML = text + text;
}

/* ===================== INIT ===================== */
function tick(){
  updateClock();
  updateNorwayCountdowns();
}

updateClock();
renderNorway();
renderBoard();
renderTicker();
setInterval(tick, 1000);
setInterval(renderNorway, 30000);
setInterval(advanceLater, 7000);
setInterval(renderBoard, 60000);
</script>
</body>
</html>
